# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas - Get from https://www.mongodb.com/cloud/atlas
# Example: mongodb+srv://username:password@cluster.mongodb.net/databasename
MONGO_URI=your_mongodb_atlas_connection_string_here

# JWT Secret - Use any random 40+ character string
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=30d

# Cloudinary (for image/video uploads)
# Get credentials from https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Perspective API (Content Moderation - FREE)
# Get from https://www.perspectiveapi.com/
PERSPECTIVE_API_KEY=your_perspective_api_key

# Sightengine (Image Moderation - FREE tier: 500 ops/month)
# Sign up at https://sightengine.com/
SIGHTENGINE_API_USER=your_sightengine_user
SIGHTENGINE_API_SECRET=your_sightengine_secret

# Admin Account (created on first run with seedAdmin.js)
ADMIN_EMAIL=admin@upgk.online
ADMIN_PASSWORD=change_this_password
